// Add lines like this to spawn processes at startup.
// Note that running niri as a session supports xdg-desktop-autostart,
// which may be more convenient to use.
// See the binds section below for more spawn examples.

spawn-at-startup "qs" "-c" "noctalia-shell"
// spawn-at-startup "xwayland-satellite"
spawn-at-startup "syncthing"
spawn-at-startup "fcitx5 -D"
spawn-at-startup "/usr/local/bin/lyrics-backend"
spawn-at-startup "kwalletd6"
spawn-at-startup "~/.local/bin/switchbg"
spawn-sh-at-startup "wl-paste --watch cliphist store"
spawn-sh-at-startup "XDG_MENU_PREFIX=arch- kbuildsycoca6"
spawn-sh-at-startup "mpd && sleep 5 && mpd-mpris"
// This line starts waybar, a commonly used bar for Wayland compositors.
// spawn-at-startup "waybar"
// spawn-at-startup "hypridle"
// spawn-at-startup "swaync"
spawn-sh-at-startup "claude-code-ui"
spawn-sh-at-startup "cd /home/ivhu/dotfile && ./update.sh"
