[{
    "height": 24, // Waybar height (to be removed for auto height)
    "layer": "top", // Waybar at top layer
    "output": ["eDP-1"],
    "margin-top": 4,
    "margin-left": 7,
    "margin-bottom": 0,
    "margin-right": 7,
    "spacing": 5, // Gaps between modules (4px)
    "modules-left": ["custom/launcher", "cpu", "memory", "custom/weather","custom/spotify", "hyprland/window"],
    "modules-center": ["hyprland/workspaces"],
    "modules-right": ["custom/speed","tray", "backlight", "pulseaudio", "battery", "clock", "custom/power-menu","custom/notify"],
    "hyprland/workspaces": {
      "format": "{icon}",
      "on-click": "activate",
      "format-icons": {
        "1": "дёҖ",
        "2": "дәҢ",
        "3": "дёү",
        "4": "еӣӣ",
        "5": "дә”",
        "6": "е…ӯ",
        "7": "дёғ",
        "urgent": "пҒӘ",
        "default": "п„‘"
      }
    },
    "hyprland/window": {
        "max-length": 20,
        "separate-outputs": true
    },
    "tray": {
        "spacing": 10
    },
    "clock": {
        "format": "<span color='#bf616a'>пҖ— </span>{:%I:%M %p}",
        "format-alt": "<span color='#bf616a'>пҒі </span>{:%a %b %d}",
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>",
    },

    "cpu": {
      "interval": 10,
      "format": "пҳҰ {}%",
      "max-length": 10,
      "on-click": "",
    },
    "memory": {
        "interval": 30,
        "format": "пҳӘ {}%",
        "format-alt":"п‘І {used:0.1f}G",
        "max-length": 10,
    },
    "backlight": {
        "device": "DP-1",
        "format": "{icon} {percent}%",
        "format-icons": ["оҺҚ", "оҸ“", "оҸ‘", "оҸҸ", "оҸҺ", "оҸҚ", "оҸҠ", "оҸҲ", "оҺӣ"],
        "on-click": "",
    },
    "network": {
        "format-wifi": "пӘЁ {signalStrength}%",
        "format-ethernet": "пӣҝ wired",
        "format-disconnected": "пӘ©",
        "format-disconnected": "Disconnected пҒұ ",
    },

    "custom/speed": {
      "restart-interval": 1,
      "exec": "bash ~/.config/waybar/scripts/net.sh",
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "пҖҘ пҠ” {volume}%",
        "format-bluetooth-muted": "пҡ© пҠ”",
        "format-muted": "пӘҖ",
        "format-icons": {
            "headphone": "пҖҘ",
            "hands-free": "п–җ",
            "headset": "п–җ",
            "phone": "пӮ•",
            "portable": "пӮ•",
            "car": "пҶ№",
            "default": ["пҖҰ", "пҖ§", "пҖЁ"]
        },
        "on-click": "pavucontrol-qt"
    },
    "custom/notify": {
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
            "notification": "пӮў <span foreground='red'><sup>п‘„</sup></span>",
            "none": "пӮў ",
            "dnd-notification": "пҮ· <span foreground='red'><sup>п‘„</sup></span>",
            "dnd-none": "пҮ· ",
            "inhibited-notification": "пӮў <span foreground='red'><sup>п‘„</sup></span>",
            "inhibited-none": "пӮў ",
            "dnd-inhibited-notification": "пҮ· <span foreground='red'><sup>п‘„</sup></span>",
            "dnd-inhibited-none": "пҮ· "
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },

    "bluetooth": {
        "on-click": "~/.config/waybar/scripts/rofi-bluetooth &",
        "format": "пҠ” {status}",
    },

    "battery": {
      "bat": "BAT0",
      "adapter": "ADP0",
      "interval": 60,
      "states": {
          "warning": 30,
          "critical": 15
      },
      "max-length": 20,
      "format": "{icon} {time}",
      "format-warning": "{icon} {capacity}%",
      "format-critical": "{icon} {capacity}%",
      "format-charging": "<span font-family='Font Awesome 6 Free'>пғ§</span> {capacity}%",
      "format-plugged": "пҮҰ  {capacity}%",
      "format-alt": "{icon} {capacity}%",
      "format-full": "пҮҰ  {capacity}%",
      "format-icons": ["пү„ ", "пүғ ", "пүӮ ", "пүҒ ", "пүҖ "],
    },
    "custom/weather": {
      "exec": "python3 ~/.config/waybar/scripts/weather.py",
      "restart-interval": 300,
      "return-type": "json",
    },

   "custom/spotify": {
    "exec": "python3 ~/.config/waybar/scripts/mediaplayer.py",
    "format": " пҶј ",
    "return-type": "json",
    "on-click": "playerctl play-pause",
    "on-double-click-right": "playerctl next",
    "on-double-click-left": "playerctl previous",
    },
    "custom/power-menu": {
        "format": " <span color='#6a92d7'>вҸ» </span>",
        "on-click": "bash ~/.config/waybar/scripts/power-menu/powermenu.sh",
    },
    "custom/launcher": {
        "format": " <span color='#6a92d7'>пһҹ </span>",
        "on-click": "rofi -show drun",
    },
},
