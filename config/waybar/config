[{
    "height": 24, // Waybar height (to be removed for auto height)
    "layer": "top", // Waybar at top layer
    "output": ["eDP-1"],
    "margin-top": 4,
    "margin-left": 7,
    "margin-bottom": 0,
    "margin-right": 7,
    "spacing": 5, // Gaps between modules (4px)
    "modules-left": ["custom/launcher", "cpu", "memory", "custom/weather","custom/spotify", "hyprland/window"],
    "modules-center": ["hyprland/workspaces"],
    "modules-right": ["custom/speed","tray", "backlight", "pulseaudio", "battery", "clock", "custom/power-menu","custom/notify"],
    "hyprland/workspaces": {
      "format": "{icon}",
      "on-click": "activate",
      "format-icons": {
        "1": "ф╕А",
        "2": "ф║М",
        "3": "ф╕Й",
        "4": "хЫЫ",
        "5": "ф║Ф",
        "6": "хЕн",
        "7": "ф╕Г",
        "urgent": "яБк",
        "default": "яДС"
      }
    },
    "hyprland/window": {
        "max-length": 20,
        "separate-outputs": true
    },
    "tray": {
        "spacing": 10
    },
    "clock": {
        "format": "<span color='#bf616a'>яАЧ </span>{:%I:%M %p}",
        "format-alt": "<span color='#bf616a'>яБ│ </span>{:%a %b %d}",
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>",
    },

    "cpu": {
      "interval": 10,
      "format": "яШж {}%",
      "max-length": 10,
      "on-click": "",
    },
    "memory": {
        "interval": 30,
        "format": "яШк {}%",
        "format-alt":"яС▓ {used:0.1f}G",
        "max-length": 10,
    },
    "backlight": {
        "device": "DP-1",
        "format": "{icon} {percent}%",
        "format-icons": ["юОН", "юПУ", "юПС", "юПП", "юПО", "юПН", "юПК", "юПИ", "юОЫ"],
        "on-click": "",
    },
    "network": {
        "format-wifi": "яки {signalStrength}%",
        "format-ethernet": "яЫ┐ wired",
        "format-disconnected": "якй",
        "format-disconnected": "Disconnected яБ▒ ",
    },

    "custom/speed": {
      "restart-interval": 1,
      "exec": "bash ~/.config/waybar/scripts/net.sh",
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "яАе яКФ {volume}%",
        "format-bluetooth-muted": "яЪй яКФ",
        "format-muted": "якА",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яЦР",
            "headset": "яЦР",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": ["яАж", "яАз", "яАи"]
        },
        "on-click": "pavucontrol-qt"
    },
    "custom/notify": {
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
            "notification": "яВв <span foreground='red'><sup>яСД</sup></span>",
            "none": "яВв ",
            "dnd-notification": "яЗ╖ <span foreground='red'><sup>яСД</sup></span>",
            "dnd-none": "яЗ╖ ",
            "inhibited-notification": "яВв <span foreground='red'><sup>яСД</sup></span>",
            "inhibited-none": "яВв ",
            "dnd-inhibited-notification": "яЗ╖ <span foreground='red'><sup>яСД</sup></span>",
            "dnd-inhibited-none": "яЗ╖ "
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },

    "bluetooth": {
        "on-click": "~/.config/waybar/scripts/rofi-bluetooth &",
        "format": "яКФ {status}",
    },

    "battery": {
      "bat": "BAT0",
      "adapter": "ADP0",
      "interval": 60,
      "states": {
          "warning": 30,
          "critical": 15
      },
      "max-length": 20,
      "format": "{icon} {time}",
      "format-warning": "{icon} {capacity}%",
      "format-critical": "{icon} {capacity}%",
      "format-charging": "<span font-family='Font Awesome 6 Free'>яГз</span> {capacity}%",
      "format-plugged": "яЗж  {capacity}%",
      "format-alt": "{icon} {capacity}%",
      "format-full": "яЗж  {capacity}%",
      "format-icons": ["яЙД ", "яЙГ ", "яЙВ ", "яЙБ ", "яЙА "],
    },
    "custom/weather": {
      "exec": "python3 ~/.config/waybar/scripts/weather.py",
      "restart-interval": 300,
      "return-type": "json",
    },

   "custom/spotify": {
    "exec": "python3 ~/.config/waybar/scripts/mediaplayer.py",
    "format": " яЖ╝ ",
    "return-type": "json",
    "on-click": "playerctl play-pause",
    "on-double-click-right": "playerctl next",
    "on-double-click-left": "playerctl previous",
    },
    "custom/power-menu": {
        "format": " <span color='#6a92d7'>тП╗ </span>",
        "on-click": "bash ~/.config/waybar/scripts/power-menu/powermenu.sh",
    },
    "custom/launcher": {
        "format": " <span color='#6a92d7'>яЮЯ </span>",
        "on-click": "rofi -show drun",
        "on-click-right": "bash ~/.config/waybar/scripts/warpaper.sh",
    },
},
